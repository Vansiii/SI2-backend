# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.tudominio.com

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_SSL_REQUIRE=True

# Email (Brevo SMTP)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-user@smtp-brevo.com
BREVO_SMTP_KEY=your-smtp-key

# Delivery mode: smtp | brevo_api | smtp_with_brevo_fallback
EMAIL_DELIVERY_METHOD=smtp

# Brevo HTTPS API (recommended on Railway Free/Trial/Hobby plans)
# BREVO_API_KEY=xkeysib-your-brevo-api-key
# BREVO_API_URL=https://api.brevo.com/v3/smtp/email

# Standard SMTP aliases (also supported by settings.py)
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-user@smtp-brevo.com
# EMAIL_HOST_PASSWORD=your-smtp-key

DEFAULT_FROM_EMAIL=no-reply@tudominio.com
DEFAULT_FROM_NAME=FinCore
EMAIL_TIMEOUT=20
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Frontend URL used in links included in transactional emails
FRONTEND_URL=https://app.tudominio.com

# CORS
CORS_ALLOWED_ORIGINS=https://app.tudominio.com
